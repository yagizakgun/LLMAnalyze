# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# News Providers
NEWSAPI_KEY=your_newsapi_key_here

# Market Data
